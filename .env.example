# ── windy-ads environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. With NO keys set, the app runs in DEMO
# mode: the full UI works and generation returns a sample stock video so you
# can develop the product without spending a cent.

# Video-generation provider. One of: heygen | did | mock
VIDEO_PROVIDER=mock

# HeyGen (https://app.heygen.com → Settings → API)
HEYGEN_API_KEY=

# D-ID (https://studio.d-id.com → API keys) — alternative video provider
DID_API_KEY=

# ElevenLabs (https://elevenlabs.io → Profile → API key) — text-to-speech voices
ELEVENLABS_API_KEY=

# Public base URL (used for absolute callback / share links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
